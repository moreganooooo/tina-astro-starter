---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/nav.astro";
---

<Layout title="Project — Morgan Escott">
  <Nav />

  <section class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <div class="reveal-content" style="animation-delay: 200ms;">
      <span class="text-accent text-[11px] uppercase tracking-widest font-body">Coming Soon</span>

      <h1 class="text-5xl md:text-7xl font-heading-display text-white mt-4 mb-6">
        Project In Progress
      </h1>

      <p class="text-gray font-body text-base max-w-md mx-auto leading-relaxed mb-12">
        This project page is on its way. Check back soon — something good is being built here.
      </p>

      <a
        href="/#projects"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-white/10 bg-white/5 text-white font-body text-sm tracking-wide transition-all duration-300 hover:border-accent/50 hover:bg-accent/10 hover:shadow-[0_0_20px_oklch(0.72_0.18_35/0.2)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
          <path d="M7.828 11H20v2H7.828l5.364 5.364-1.414 1.414L4 12l7.778-7.778 1.414 1.414z"/>
        </svg>
        Back to Projects
      </a>
    </div>

    <!-- Decorative accent line -->
    <div class="reveal-content absolute bottom-0 left-1/2 -translate-x-1/2 w-px h-32 bg-gradient-to-b from-accent/40 to-transparent" style="animation-delay: 600ms;"></div>
  </section>
</Layout>

<style>
  section {
    position: relative;
  }
</style>
