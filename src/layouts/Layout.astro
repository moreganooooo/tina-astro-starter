---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <title>{title}</title>
    <link rel="preconnect" href="https://api.fontshare.com">
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..900;1,6..96,400..900&family=Satoshi:wght@300..700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-background relative min-h-screen overflow-x-hidden antialiased">
    <div 
      id="matrix-container" 
      class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none"
      style="mask-image: linear-gradient(to bottom, black 0%, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 80%, transparent 100%);"
    ></div>

    <main class="px-2 sm:px-12 md:px-14 lg:px-28 max-w-360 mx-auto relative z-0">
        <slot />
    </main>

    <button
      id="flow-btn"
      class="hidden md:flex fixed top-8 right-8 z-50 items-center gap-2 cursor-pointer group"
      aria-label="Change particle flow"
    >
      <span id="flow-label">Change Flow</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
        <path d="M12 15.5A3.5 3.5 0 0 1 8.5 12 3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5m7.43-2.92c.04-.34.07-.68.07-1.08s-.03-.74-.07-1.08l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.34-.07.69-.07 1.08s.03.74.07 1.08l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65Z"/>
      </svg>
    </button>

    <button
      id="to-top"
      class="fixed bottom-8 right-8 z-50 p-0 rounded-full bg-background border border-white/10 shadow-2xl transition-all duration-500 translate-y-20 opacity-0 group flex items-center justify-center cursor-pointer"
      aria-label="Back to top"
    >
      <svg class="w-14 h-14 -rotate-90">
        <circle cx="28" cy="28" r="24" fill="none" stroke="currentColor" stroke-width="3" class="text-white/5"></circle>
        <circle
          id="progress-circle"
          cx="28" cy="28" r="24"
          fill="none"
          stroke="currentColor" 
          stroke-width="3"
          stroke-dasharray="150.7"
          stroke-dashoffset="150.7"
          stroke-linecap="round"
          class="text-accent transition-all duration-100"
        ></circle>
      </svg>
      
      <div class="absolute text-accent group-hover:scale-110 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M13.0001 7.82843V20H11.0001V7.82843L5.63614 13.1924L4.22192 11.7782L12.0001 4L19.7783 11.7782L18.3641 13.1924L13.0001 7.82843Z"></path>
        </svg>
      </div>
    </button>

    <script>
      const container = document.getElementById('matrix-container');
      const ACCENT = 'oklch(0.72 0.18 35 / 0.45)';
      const FLOW_NAMES = ['cosmic-float', 'cosmic-flow', 'cosmic-spiral'] as const;
      const FLOW_EASING = ['linear', 'ease-in-out', 'ease-in-out'] as const;

      let particles: { element: HTMLElement; x: number; y: number }[] = [];
      let flowPattern = 0;

      function setAnimation(el: HTMLElement) {
        const duration = Math.random() * 15 + 10;
        const delay = Math.random() * -20;
        const alternate = flowPattern > 0 ? ' alternate' : '';
        el.style.animation = `${FLOW_NAMES[flowPattern]} ${duration}s ${FLOW_EASING[flowPattern]} ${delay}s infinite${alternate}`;
      }

      function createParticles(count: number) {
        if (!container) return;
        for (let i = 0; i < count; i++) {
          const el = document.createElement('div');
          el.className = 'cosmic-particle';
          const x = Math.random() * 100;
          const y = Math.random() * 100;
          const size = Math.random() * 4 + 2;
          el.style.left = `${x}vw`;
          el.style.top = `${y}vh`;
          el.style.width = `${size}px`;
          el.style.height = `${size}px`;
          el.style.background = ACCENT;
          el.style.boxShadow = `0 0 ${size * 2}px ${ACCENT}`;
          el.style.opacity = (Math.random() * 0.4 + 0.1).toString();
          setAnimation(el);
          container.appendChild(el);
          particles.push({ element: el, x, y });
        }
      }

      function createStaticParticles(count: number) {
        if (!container) return;
        for (let i = 0; i < count; i++) {
          const el = document.createElement('div');
          el.className = 'cosmic-particle';
          el.style.left = `${Math.random() * 100}vw`;
          el.style.top = `${Math.random() * 90}vh`;
          const size = Math.random() * 4 + 2;
          el.style.width = `${size}px`;
          el.style.height = `${size}px`;
          el.style.background = ACCENT;
          el.style.boxShadow = `0 0 ${size * 2}px ${ACCENT}`;
          el.style.opacity = (Math.random() * 0.3 + 0.1).toString();
          container.appendChild(el);
        }
      }

      if (window.innerWidth > 768) {
        createParticles(150);

        document.addEventListener('mousemove', (e) => {
          const mx = (e.clientX / window.innerWidth) * 100;
          const my = (e.clientY / window.innerHeight) * 100;
          particles.forEach(p => {
            const dx = mx - p.x;
            const dy = my - p.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 20) {
              const force = (20 - dist) / 2;
              const angle = Math.atan2(dy, dx);
              p.element.style.transform = `translate(${Math.cos(angle) * force}px, ${Math.sin(angle) * force}px)`;
            } else {
              p.element.style.transform = '';
            }
          });
        });

        document.getElementById('flow-btn')?.addEventListener('click', () => {
          flowPattern = (flowPattern + 1) % 3;
          particles.forEach(p => setAnimation(p.element));
        });
      } else {
        createStaticParticles(30);
      }

      
      // ** SCROLL TO TOP ** //
      const toTopBtn = document.getElementById('to-top');
      const progressCircle = document.getElementById('progress-circle');
      const circumference = 150.796; // 2 * pi * 24
      const arrowIcon = toTopBtn?.querySelector('.absolute');

      function handleScroll() {
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercentage = window.scrollY / scrollHeight;
        
        // Update the Circle Progress
        const offset = circumference - (scrollPercentage * circumference);
        if (progressCircle) {
          progressCircle.style.strokeDashoffset = offset.toString();
        }

        // Visibility Logic (Appear at 50%)
        if (scrollPercentage > 0.5) {
          toTopBtn?.classList.remove('translate-y-20', 'opacity-0');
          toTopBtn?.classList.add('translate-y-0', 'opacity-100');
        } else {
          toTopBtn?.classList.add('translate-y-20', 'opacity-0');
          toTopBtn?.classList.remove('translate-y-0', 'opacity-100');
        }

        // Bounce Logic at 98%
        if (scrollPercentage > 0.98) {
          arrowIcon?.classList.add('animate-bounce-twice');
        } else {
          arrowIcon?.classList.remove('animate-bounce-twice');
        }
      }

      window.addEventListener('scroll', handleScroll, { passive: true });

      // toTopBtn?.addEventListener('click', () => {
      //   window.scrollTo({ top: 0, behavior: 'smooth' });
      // });

      toTopBtn?.addEventListener('click', () => {
      arrowIcon?.classList.add('launching');

      const startPosition = window.scrollY;
      const duration = 750;
      let startTime: number | null = null;
      let requestID: number; // storing the ID here

      const stopAnimation = () => {
        cancelAnimationFrame(requestID);
        arrowIcon?.classList.remove('launching');
        // Remove listeners once stopped
        window.removeEventListener('wheel', stopAnimation);
        window.removeEventListener('touchmove', stopAnimation);
      };

      function easeOutQuad(t: number, b: number, c: number, d: number) {
        t /= d;
        return -c * t * (t - 2) + b;
      }

      function animation(currentTime: number) {
        if (startTime === null) startTime = currentTime;
        const timeElapsed = currentTime - startTime;
        const run = easeOutQuad(timeElapsed, startPosition, -startPosition, duration);
        
        window.scrollTo(0, run);

        if (timeElapsed < duration) {
          requestID = requestAnimationFrame(animation);
        } else {
          stopAnimation();
        }
      }

      // Listen for any user interruption
      window.addEventListener('wheel', stopAnimation, { once: true });
      window.addEventListener('touchmove', stopAnimation, { once: true });

      requestID = requestAnimationFrame(animation);
    });

    </script>
    <script>
      import '../scripts/roleSwitcher.js';
    </script>

    <style>
      #flow-btn {
        background: none;
        border: none;
        padding: 0;
      }

      #flow-btn svg {
        color: oklch(0.72 0.18 35 / 0.45);
        transition: color 600ms ease, filter 600ms ease;
      }
      #flow-btn:hover svg {
        color: oklch(0.72 0.18 35);
        filter: drop-shadow(0 0 6px oklch(0.72 0.18 35 / 0.45));
      }

      #flow-label {
        color: oklch(0.72 0.18 35);
        font-family: var(--font-body);
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        white-space: nowrap;
        opacity: 0;
        transform: translateX(6px);
        transition: opacity 600ms ease, transform 600ms ease;
      }
      #flow-btn:hover #flow-label {
        opacity: 1;
        transform: translateX(0);
      }
    </style>
  </body>
</html>