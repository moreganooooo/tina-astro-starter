---
import { Icon } from 'astro-icon/components';

interface Project {
  title: string;
  description: string;
  images: string[];
  tech: string[];
  platforms: string[];
  link: string;
  category: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const isSlider = project.images.length > 1;
---

<a
  href={project.link}
  target={project.link.startsWith('http') ? '_blank' : '_self'}
  class="project-card group relative bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-accent/40 transition-all duration-500 block"
  data-roles="all"
>
  <div class="aspect-video overflow-hidden relative bg-[#180a30]">
    <div class="absolute inset-0 bg-accent/10 group-hover:bg-transparent transition-colors z-10 pointer-events-none"></div>

    <div class={`w-full h-full relative ${isSlider ? 'image-slider' : ''}`}>
      {project.images.map((img, index) => (
        <img
          src={img}
          alt={`${project.title} screenshot ${index + 1}`}
          onerror="this.onerror=null;this.src='placeholder.jpeg';"
          class={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 ${index === 0 ? 'opacity-100 z-0' : 'opacity-0 z-[-1]'}`}
        />
      ))}
    </div>

    <div class="absolute top-3 right-3 flex gap-2 z-20">
      {project.platforms.map((p) => (
        <div class="p-1.5 bg-black/60 backdrop-blur-md rounded-lg border border-white/10 text-white/80">
          <Icon name={`mdi:${p}`} class="w-4 h-4" />
        </div>
      ))}
    </div>
  </div>

  <div class="p-6 space-y-4">
    <div>
      <span class="text-accent text-[10px] uppercase tracking-widest">{project.category}</span>
      <h3 class="text-xl font-heading text-white mt-1">{project.title}</h3>
    </div>

    <p class="text-gray-400 text-sm font-body line-clamp-3">
      {project.description}
    </p>

    <div class="flex flex-wrap gap-2 pt-2">
      {project.tech.map((t) => (
        <span class="px-2 py-1 bg-white/5 rounded-md text-[10px] text-white/60 border border-white/5">
          {t}
        </span>
      ))}
    </div>
  </div>
</a>

<script>
  function initSliders() {
    const sliders = document.querySelectorAll('.image-slider');
    
    sliders.forEach(slider => {
      const images = slider.querySelectorAll('img');
      if (images.length <= 1) return;

      let currentIndex = 0;
      setInterval(() => {
        // Hide current
        images[currentIndex].classList.remove('opacity-100', 'z-0');
        images[currentIndex].classList.add('opacity-0', 'z-[-1]');
        
        // Move to next
        currentIndex = (currentIndex + 1) % images.length;
        
        // Show next
        images[currentIndex].classList.remove('opacity-0', 'z-[-1]');
        images[currentIndex].classList.add('opacity-100', 'z-0');
      }, 3500);
    });
  }

  initSliders();
  document.addEventListener('astro:after-swap', initSliders);
</script>

<style is:global>
  .project-card {
    opacity: 0;
    visibility: hidden;
    transform: translateY(40px);
    transition: 
      opacity 0.8s ease-out, 
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.8s;
    will-change: transform, opacity;
  }

  .project-card.reveal {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
</style>