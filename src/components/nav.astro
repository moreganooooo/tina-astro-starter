---
import { Icon } from 'astro-icon/components';
interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  {
    label: "Home",
    href: "#home",
    icon: `mdi:home`,
  },
  {
    label: "Career",
    href: "#career",
    icon: `mdi:work`,
  },
  {
    label: "Projects",
    href: "#projects",
    icon: `mdi:computer`,
  },
  {
    label: "Tech",
    href: "#tech",
    icon: `mdi:code-tags`,
  },
  {
    label: "Contact",
    href: "#contact",
    icon: `mdi:message`,
  }
];
---

<!-- Shared fixed row: role-switcher + nav pill sit as flex siblings -->
<div
  id="nav-row"
  class="fixed z-20 md:top-6 md:left-1/2 md:-translate-x-1/2 flex items-center gap-2"
>
  <!-- Desktop role switcher -->
  <div class="hidden md:flex relative" id="role-switcher">
    <button
      class="role-switcher__trigger"
      aria-haspopup="listbox"
      aria-expanded="false"
      id="role-trigger"
    >
      <span class="role-label">Viewing: General</span>
      <svg width="10" height="10" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
        <path d="M6 8L1 3h10L6 8z"/>
      </svg>
    </button>

    <ul class="role-switcher__menu" role="listbox" aria-labelledby="role-trigger" hidden>
      <li role="option" data-role="general"   aria-selected="true">✦ General</li>
      <li role="option" data-role="sales-ops" aria-selected="false">Sales Operations &amp; CRM</li>
      <li role="option" data-role="marketing" aria-selected="false">Marketing &amp; Copywriting</li>
      <li role="option" data-role="creative"  aria-selected="false">Branding &amp; Creative</li>
      <li role="option" data-role="admin"     aria-selected="false">Executive &amp; Admin Support</li>
    </ul>
  </div>

  <!-- Nav pill: only page links, no switcher inside -->
  <nav
    id="main-nav"
    class="border-[1.2px] border-transparent"
  >
    <div class="flex justify-center items-center px-6 py-3 w-full">
      <ul class="flex w-full justify-between md:space-x-6 md:justify-center md:gap-8 gap-1">
        {
          navItems.map((item) => (
            <li class="flex-1 md:flex-none">
              <a
                href={item.href}
                class="flex flex-col items-center gap-1 text-gray-400 transition-colors text-xs md:text-base relative group"
              >
                <div class="absolute -left-6 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full transition-all duration-300 scale-0 opacity-0 nav-indicator hidden md:block" />
                <span class="md:hidden flex items-center justify-center w-6 h-6">
                  <Icon
                    name={item.icon}
                    class="nav-icon w-full h-full text-gray-400 group-hover:text-accent transition-colors duration-300"
                  />
                </span>
                <span class="hidden md:inline-block">{item.label}</span>
                <span class="md:hidden text-xs">{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</div>

<!-- Mobile: floating pill above bottom nav -->
<button
  id="role-trigger-mobile"
  class="md:hidden"
  aria-haspopup="dialog"
  aria-expanded="false"
>
  <span class="role-label">Viewing: General</span>
  <svg width="9" height="9" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
    <path d="M6 8L1 3h10L6 8z"/>
  </svg>
</button>

<!-- Mobile: backdrop -->
<div id="role-sheet-backdrop" class="md:hidden"></div>

<!-- Mobile: bottom sheet -->
<div
  id="role-sheet"
  class="md:hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="role-sheet-title"
>
  <div class="role-sheet__inner">
    <div class="role-sheet__handle"></div>
    <p id="role-sheet-title" class="role-sheet__eyebrow">Viewing as</p>
    <ul role="listbox">
      <li role="option" data-role="general"   aria-selected="true">✦ General</li>
      <li role="option" data-role="sales-ops" aria-selected="false">Sales Operations & CRM</li>
      <li role="option" data-role="marketing" aria-selected="false">Marketing & Copywriting</li>
      <li role="option" data-role="creative"  aria-selected="false">Branding & Creative</li>
      <li role="option" data-role="admin"     aria-selected="false">Executive & Admin Support</li>
    </ul>
  </div>
</div>

<style>
  /* ── Entrance animation: opacity-only, no translate jitter ── */
  #nav-row {
    opacity: 0;
    animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) 700ms forwards;
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* ── Nav pill ── */
  nav {
    background-color: transparent;
    border-color: transparent;
    backdrop-filter: blur(0px);
    transition:
      background-color 0.4s ease,
      backdrop-filter 0.4s ease,
      border-radius 0.4s ease,
      border-color 0.4s ease;
  }

  nav.scrolling {
    background-color: color-mix(in srgb, var(--color-background), transparent 75%);
    border-color: #ffffff20;
    border-radius: 9999px;
    backdrop-filter: blur(10px);
  }

  nav a.active .nav-indicator {
    transform: translateY(-50%) scale(1);
    opacity: 1;
  }

  nav a {
    transition: transform 0.3s ease, color 0.3s ease, font-weight 0.3s ease;
  }

  nav a.active {
    color: white !important;
    font-weight: 700;
    transform: scale(1.1);
  }

  nav a.active span {
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
  }

  nav li {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .nav-icon {
    transition: transform 0.3s ease, color 0.3s ease, filter 0.3s ease;
  }

  nav a.active .nav-icon {
    color: var(--color-accent) !important;
    transform: scale(1.2);
    filter: drop-shadow(0 0 8px var(--color-accent));
  }

  nav a:not(.active):hover {
    color: var(--color-accent) !important;
  }

  nav a:not(.active):hover span {
    transform: scale(0.95);
    text-shadow: 0 0 15px var(--color-accent-60);
  }

  nav a:not(.active):hover .nav-icon {
    transform: scale(0.95);
    color: var(--color-accent) !important;
  }

  /* ── Mobile overrides ── */
  @media (max-width: 767px) {
    body {
      padding-bottom: 70px;
    }

    #nav-row {
      bottom: 0;
      left: 0;
      right: 0;
      display: block;
      animation: none;
      opacity: 1;
    }

    nav {
      width: 100% !important;
      border-radius: 1.5rem 1.5rem 0 0;
      background-color: color-mix(in srgb, var(--color-background), transparent 10%);
      backdrop-filter: blur(10px);
      border-top: 1px solid rgba(255, 255, 255, 0.15);
      border-color: transparent;
    }

    nav.scrolling {
      border-radius: 1.5rem 1.5rem 0 0;
      width: 100% !important;
    }

    #main-nav {
      will-change: transform;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                  background-color 0.4s ease,
                  backdrop-filter 0.4s ease;
      background-clip: padding-box;
    }

    #main-nav.nav-hidden {
      transform: translateY(110%) !important;
      backdrop-filter: blur(0px);
    }

    #role-trigger-mobile {
      display: flex;
    }
  }

  /* ── Role Switcher (desktop dropdown) ── */
  .role-switcher__trigger {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    border: 1px solid oklch(0.72 0.18 35 / 0.35);
    border-radius: 9999px;
    background: oklch(0.72 0.18 35 / 0.08);
    color: oklch(0.72 0.18 35);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: all 200ms ease;
    white-space: nowrap;
  }
  .role-switcher__trigger:hover {
    background: oklch(0.72 0.18 35 / 0.15);
    border-color: oklch(0.72 0.18 35 / 0.6);
  }

  .role-switcher__menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 220px;
    background: color-mix(in srgb, #16062a 95%, transparent);
    backdrop-filter: blur(12px);
    border: 1px solid oklch(0.72 0.18 35 / 0.2);
    border-radius: 0.75rem;
    padding: 0.4rem;
    list-style: none;
    z-index: 100;
    box-shadow: 0 8px 32px oklch(0 0 0 / 0.4), 0 0 60px oklch(0.72 0.18 35 / 0.08);
  }
  .role-switcher__menu[hidden] { display: none; }

  .role-switcher__menu li {
    padding: 0.5rem 0.85rem;
    border-radius: 0.5rem;
    font-size: 0.8rem;
    color: oklch(0.85 0.02 35);
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease;
  }
  .role-switcher__menu li:hover,
  .role-switcher__menu li[aria-selected="true"] {
    background: oklch(0.72 0.18 35 / 0.12);
    color: oklch(0.72 0.18 35);
  }

  /* ── Mobile pill ── */
  #role-trigger-mobile {
    position: fixed;
    bottom: 74px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 30;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.85rem;
    border: 1px solid oklch(0.72 0.18 35 / 0.35);
    border-radius: 9999px;
    background: oklch(0.72 0.18 35 / 0.08);
    color: oklch(0.72 0.18 35);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    white-space: nowrap;
    backdrop-filter: blur(8px);
    transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform, opacity;
  }

  #role-trigger-mobile.pill-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(120%);
  }

  /* ── Mobile backdrop ── */
  #role-sheet-backdrop {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  #role-sheet-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Mobile bottom sheet ── */
  #role-sheet {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }
  #role-sheet.open {
    transform: translateY(0);
  }

  .role-sheet__inner {
    background: color-mix(in srgb, #16062a 97%, transparent);
    border-top: 1px solid oklch(0.72 0.18 35 / 0.2);
    border-radius: 1.25rem 1.25rem 0 0;
    padding: 0.75rem 1rem 2.5rem;
  }

  .role-sheet__handle {
    width: 2.5rem;
    height: 0.25rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.2);
    margin: 0 auto 1rem;
  }

  .role-sheet__eyebrow {
    font-size: 0.65rem;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    padding: 0 0.5rem;
    margin-bottom: 0.5rem;
  }

  #role-sheet ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #role-sheet li {
    padding: 0.8rem 0.75rem;
    border-radius: 0.75rem;
    font-size: 0.95rem;
    font-family: var(--font-body);
    color: oklch(0.85 0.02 35);
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease;
  }

  #role-sheet li:hover,
  #role-sheet li[aria-selected="true"] {
    background: oklch(0.72 0.18 35 / 0.12);
    color: oklch(0.72 0.18 35);
  }
</style>

<script>
  const nav = document.getElementById("main-nav");
  let lastScrollY = window.scrollY;
  let rafId: number | null = null;

  function updateNav() {
    const currentScrollY = window.scrollY;

    if (currentScrollY > 0) {
      nav?.classList.add("scrolling");
    } else {
      nav?.classList.remove("scrolling");
    }

    if (window.innerWidth < 768) {
      const mobilePill = document.getElementById("role-trigger-mobile");
      if (currentScrollY > lastScrollY && currentScrollY > 50) {
        nav?.classList.add("nav-hidden");
        mobilePill?.classList.add("pill-hidden");
      } else {
        nav?.classList.remove("nav-hidden");
        mobilePill?.classList.remove("pill-hidden");
      }
    }

    lastScrollY = currentScrollY;
    rafId = null;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (!rafId) {
        rafId = requestAnimationFrame(updateNav);
      }
    },
    { passive: true }
  );

  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      e.preventDefault();
      const target = e.currentTarget as HTMLAnchorElement;
      const targetId = target.getAttribute("href")?.substring(1) || "";
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        targetElement.scrollIntoView({ behavior: "smooth" });
      }
    });
  });

  document.addEventListener("DOMContentLoaded", () => {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll("nav a[href^='#']");
    const observerOptions = { threshold: 0.5 };

    const observerCallback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => link.classList.remove("active"));
          const id = entry.target.getAttribute("id");
          const activeLink = document.querySelector(`nav a[href="#${id}"]`);
          if (activeLink) {
            activeLink.classList.add("active");
          }
        }
      });
    };

    const observer = new IntersectionObserver(observerCallback, observerOptions);
    sections.forEach((section) => observer.observe(section));
  });
</script>
